# RateEngine V7 CLI configuration.
# Copy to ".env" and adjust. Values mirror the legacy config.app.php defaults.
# The .env file is read by re_cli/config.py; never commit real credentials.

# --- RE7 database (current engine schema; legacy config.app.php used dbname "re7") ---
RE7_DB_HOST=127.0.0.1
RE7_DB_PORT=5432
RE7_DB_NAME=re7
RE7_DB_USER=global
RE7_DB_PASS=_cfg.access

# --- RE5 database (legacy schema, used by lib.re5.php; leave blank if unused) ---
RE5_DB_HOST=127.0.0.1
RE5_DB_PORT=5432
RE5_DB_NAME=
RE5_DB_USER=global
RE5_DB_PASS=_cfg.access

# --- FreeSWITCH CDR database (lib.cdrserver.php inserted into "fs_cdrs") ---
CDR_DB_HOST=127.0.0.1
CDR_DB_PORT=5432
CDR_DB_NAME=fs_cdrs
CDR_DB_USER=global
CDR_DB_PASS=_cfg.access

# --- MyCC control-plane server (config.app.php cc_host/cc_port) ---
MYCC_HOST=127.0.0.1
MYCC_PORT=9090

# --- Billing defaults (config.app.php $RE) ---
RE_BILLING_DAY=01
RE_CREDIT_LIMIT=50.00
RE_ROUNDING=0
